{
  "buildCommand": "pnpm run build",
  "outputDirectory": "build/client",
  "installCommand": "pnpm install",
  "framework": "remix",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "build/server/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "env": {
    "NODE_VERSION": "20.x"
  }
}
